# Supabase: conexão via pooler (porta 6543) usada pela aplicação em runtime
DATABASE_URL="postgresql://postgres.PROJECT_REF:SENHA@aws-0-REGIAO.pooler.supabase.com:6543/postgres?pgbouncer=true"

# Supabase: conexão direta (porta 5432) usada pelo prisma migrate
DIRECT_URL="postgresql://postgres.PROJECT_REF:SENHA@aws-0-REGIAO.pooler.supabase.com:5432/postgres"

# Segredo para assinar JWTs (gere algo longo e aleatório)
JWT_SECRET="troque-este-valor-por-um-segredo-longo-aleatorio"

# Validade do token (ex.: 7d, 12h)
JWT_EXPIRES_IN="7d"

# Porta opcional do servidor (padrão 3000)
PORT=3000
